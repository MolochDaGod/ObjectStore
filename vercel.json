{
  "alias": ["info.grudge-studio.com"],
  "buildCommand": "node scripts/sync-docs-canonical.mjs",
  "outputDirectory": ".",
  "framework": null,
  "redirects": [
    { "source": "/", "destination": "/docs", "permanent": true },
    { "source": "/index.html", "destination": "/docs", "permanent": true }
  ],
  "headers": [
    {
      "source": "/api/v1/(.*).json",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" },
        { "key": "Content-Type", "value": "application/json; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400, stale-while-revalidate=604800" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/api/search",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" },
        { "key": "Content-Type", "value": "application/json; charset=utf-8" }
      ]
    },
    {
      "source": "/api/stats",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Content-Type", "value": "application/json; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" }
      ]
    },
    {
      "source": "/(icons|sprites|backgrounds|images|effects|map_nodes|branding|audio|video|heroes)/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=3600" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/search", "destination": "/api/search.js" },
    { "source": "/api/stats", "destination": "/api/stats.js" },
    { "source": "/api/export", "destination": "/api/export.js" }
  ],
  "cleanUrls": false,
  "trailingSlash": false
}
