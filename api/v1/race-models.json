      "name": "Elf",
      "faction": "fabled",
      "prefix": "ELF_",
      "format": "fbx",
      "model": "elf/ELF_Characters_customizable.fbx",
      "thumbnail": "elf/thumb.png",
      "scale": 0.04,
      "yOffset": 0,
      "defaultAnimPack": "longbow",
      "allowedWeapons": ["bow", "sword", "spear", "staff"]
