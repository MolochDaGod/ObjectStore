{
  "$schema": "https://molochdagod.github.io/ObjectStore/schemas/race-models.v1.json",
  "version": "1.0.0",
  "updated": "2026-04-22",
  "base": "https://objects.grudge-studio.com/race-characters/",
  "notes": "The six canonical Grudge MMO race characters. Each model is a single FBX 'customizable kit' exported from the Unity Toon_RTS project. Every armor/weapon/shield/utility variant is a sibling child mesh of the rig; runtime equipment is done by toggling `visible` on children whose name matches `prefix` + slot regex (see `slotPatterns`). Weapons/shields attach to `boneContainers`.",

  "boneContainers": {
    "rightHand":  "R_hand_container",
    "leftHand":   "L_hand_container",
    "leftShield": "L_shield_container",
    "bag":        "Bone_bag",
    "wood":       "Bone_wood",
    "quiver":     "Quiver_container"
  },

  "slotPatterns": {
    "body":      "^Units_Body_([A-Z])$",
    "arms":      "^Units_Arms_([A-Z])$",
    "legs":      "^Units_Legs_([A-Z])$",
    "head":      "^Units_head_([A-Z])$",
    "shoulders": "^Units_shoulderpads_([A-Z])$",
    "axe":       "^Units_axe_([A-Z])$|^weapon_Axe_([A-Z])$",
    "hammer":    "^Units_hammer_([A-Z])$|^weapon_hammer_([A-Z])$",
    "sword":     "^Units_sword_([A-Z])$|^weapon_Sword_([A-Z])$",
    "pick":      "^Units_pick$",
    "spear":     "^Units_spear$|^weapon_Spear$",
    "bow":       "^Units_Bow$|^weapon_Bow$",
    "staff":     "^Units_staff_([A-Z])$|^weapon_staff_([A-Z])$",
    "shield":    "^Units_shield_([A-Z])$|^Shield_([A-Z])$",
    "bag":       "^Xtra_bag$|^Units_bag$",
    "wood":      "^Xtra_wood$|^Units_wood$",
    "quiver":    "^Xtra_quiver$|^Units_quiver$"
  },

  "slotGroups": {
    "armor":   ["body", "arms", "legs", "head", "shoulders"],
    "weapons": ["axe", "hammer", "sword", "pick", "spear", "bow", "staff"],
    "shields": ["shield"],
    "utility": ["bag", "wood", "quiver"]
  },

  "races": {
    "human": {
      "id": "human",
      "name": "Human (Western Kingdom)",
      "faction": "crusade",
      "prefix": "WK_",
      "format": "fbx",
      "model": "wk/WK_Characters_customizable.fbx",
      "thumbnail": "wk/thumb.png",
      "scale": 0.04,
      "yOffset": 0,
      "defaultAnimPack": "1h_sword_shield",
      "allowedWeapons": ["sword", "hammer", "axe", "spear", "bow", "staff"]
    },
    "barbarian": {
      "id": "barbarian",
      "name": "Barbarian",
      "faction": "crusade",
      "prefix": "BRB_",
      "format": "fbx",
      "model": "brb/BRB_Characters_customizable.fbx",
      "thumbnail": "brb/thumb.png",
      "scale": 0.04,
      "yOffset": 0,
      "defaultAnimPack": "2h_melee",
      "allowedWeapons": ["axe", "hammer", "sword", "spear"]
    },
    "elf": {
