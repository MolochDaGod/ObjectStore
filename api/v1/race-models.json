      "thumbnail": "dwf/thumb.png",
      "scale": 0.04,
      "yOffset": 0,
      "defaultAnimPack": "2h_melee",
      "allowedWeapons": ["axe", "hammer", "sword", "pick"]
    },
    "orc_classic": {
      "id": "orc_classic",
      "name": "Orc",
      "faction": "legion",
      "prefix": "ORC_",
      "format": "fbx",
      "model": "orc/ORC_Characters_Customizable.fbx",
      "thumbnail": "orc/thumb.png",
      "scale": 0.04,
      "yOffset": 0,
      "defaultAnimPack": "2h_melee",
      "allowedWeapons": ["axe", "hammer", "sword", "spear"]
