{
  "name": "@grudge-studio/objectstore",
  "version": "3.0.0",
  "type": "module",
  "description": "Grudge Studio ObjectStore — Public game data API, SDK, MCP server, and asset browser for Grudge Warlords",
  "main": "./integrations/grudge-studio-core.js",
  "module": "./integrations/grudge-studio-core.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./integrations/grudge-studio-core.js",
      "require": "./integrations/grudge-studio-core.js"
    },
    "./sdk": {
      "import": "./sdk/grudge-sdk.js"
    },
    "./sdk/r2": {
      "import": "./sdk/r2-client.js"
    },
    "./utils": {
      "import": "./utils/item-registry.js"
    },
    "./integrations": {
      "import": "./integrations/grudge-studio-core.js"
    },
    "./mcp": {
      "import": "./mcp/objectstore-server.js"
    }
  },
  "files": [
    "integrations/",
    "sdk/",
    "utils/",
    "types/",
    "css/",
    "js/",
    "mcp/",
    "api/",
    "audio/",
    "video/",
    "heroes/",
    "branding/",
    "openapi.yaml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
