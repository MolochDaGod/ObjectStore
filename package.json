{
  "name": "@grudge-studio/objectstore",
  "version": "3.0.0",
  "description": "Grudge Studio ObjectStore — Public game data API, SDK, MCP server, and asset browser for Grudge Warlords",
  "main": "./integrations/grudge-studio-core.js",
  "module": "./integrations/grudge-studio-core.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./integrations/grudge-studio-core.js",
      "require": "./integrations/grudge-studio-core.js"
    },
    "./sdk": {
      "import": "./sdk/grudge-sdk.js"
    },
    "./sdk/r2": {
      "import": "./sdk/r2-client.js"
    },
    "./utils": {
      "import": "./utils/item-registry.js"
    },
    "./integrations": {
      "import": "./integrations/grudge-studio-core.js"
    },
    "./mcp": {
      "import": "./mcp/objectstore-server.js"
    }
  },
  "files": [
    "integrations/",
    "sdk/",
    "utils/",
    "types/",
    "css/",
    "js/",
    "mcp/",
    "api/",
    "audio/",
    "video/",
    "heroes/",
    "branding/",
    "openapi.yaml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build": "echo 'No build needed - pure ES modules'",
    "test": "echo 'Tests coming soon'",
    "prepublishOnly": "npm run validate",
    "validate": "echo 'Validating package...'",
    "rebuild:sprites2d": "node ./scripts/rebuild-sprites2d.mjs",
    "dedup:sprites": "node ./scripts/dedup-sprites.mjs",
    "generate:registry": "node ./scripts/generate-asset-registry.mjs",
    "generate:sprites": "node ./scripts/organize-rpg-modular.mjs",
    "generate:changelog": "node ./scripts/generate-changelog.mjs",
    "optimize:images": "node ./scripts/optimize-images.mjs",
    "validate:schemas": "node ./scripts/validate-schemas.mjs",
    "extract:gamedata": "node ./scripts/extract-game-data.mjs",
    "audit:puter": "node ./scripts/puter-audit.mjs",
    "audit:puter:save": "node ./scripts/puter-audit.mjs --output docs/reports/puter-audit-report.json",
    "sync": "node ./scripts/sync-all.js",
    "mcp": "node ./mcp/objectstore-server.js",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "worker:tail": "wrangler tail",
    "generate:master": "node scripts/generate-master-database.mjs",
    "import:recipes": "node scripts/import-game-recipes.mjs",
    "consolidate:game-data": "node scripts/consolidate-game-data.mjs",
    "generate:all": "npm run generate:master && npm run import:recipes && npm run consolidate:game-data",
    "build:grudgedot": "node scripts/build-grudgedot-manifest.mjs",
    "export:weapon-skills": "node scripts/export-weapon-skills.mjs",
    "build:all": "npm run export:weapon-skills && npm run build:grudgedot",
    "d1:migrate": "wrangler d1 execute objectstore-meta --file=workers/schema.sql",
    "pipeline:convert": "node scripts/gltf-pipeline.mjs convert",
    "pipeline:optimize": "node scripts/gltf-pipeline.mjs optimize",
    "pipeline:animations": "node scripts/gltf-pipeline.mjs animations",
    "pipeline:effects": "node scripts/gltf-pipeline.mjs effects",
    "pipeline:validate": "node scripts/gltf-pipeline.mjs validate",
    "pipeline:all": "node scripts/gltf-pipeline.mjs all",
    "pipeline:dry": "node scripts/gltf-pipeline.mjs all --dry-run",
    "effects:consolidate": "node scripts/consolidate-effects.mjs",
    "effects:manifest": "node scripts/rebuild-effects-manifest.mjs",
    "effects:all": "node scripts/consolidate-effects.mjs && node scripts/rebuild-effects-manifest.mjs && node scripts/gltf-pipeline.mjs effects && node scripts/gltf-pipeline.mjs validate",
    "pipeline:sync": "node scripts/sync-to-r2.js --pipeline",
    "pipeline:sync:dry": "node scripts/sync-to-r2.js --pipeline --dry-run",
    "shader-lab:manifest": "node scripts/shader-lab-manifest.mjs",
    "shader-lab:sync-textures": "node scripts/shader-lab-sync-textures.mjs",
    "shader-lab:sync-textures:dry": "node scripts/shader-lab-sync-textures.mjs --dry-run",
    "import:asset-packs-2026-04": "pwsh -NoProfile -File ./scripts/import-asset-packs-2026-04.ps1",
    "build:new-registries": "node ./scripts/build-new-asset-registries.mjs",
    "build:new-registries:dry": "node ./scripts/build-new-asset-registries.mjs --dry",
    "generate:relics": "node scripts/generate-master-relics.js",
    "generate:mystic-tree": "node scripts/generate-mystic-tree.js",
    "generate:t0-addendum": "node scripts/generate-t0-addendum.js",
    "admin:merge": "node scripts/admin-merge.js",
    "import:craftpix-batch": "pwsh -NoProfile -File ./scripts/import-craftpix-batch-2026-04b.ps1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MolochDaGod/ObjectStore.git"
  },
  "keywords": [
    "grudge",
    "grudge-studio",
    "grudge-warlords",
    "game-api",
    "object-store",
    "arsenal",
    "uuid",
    "gaming",
    "rpg",
    "crafting",
    "items",
    "weapons",
    "materials",
    "puter"
  ],
  "author": {
    "name": "Grudge Studio",
    "email": "games@grudgestudio.org"
  },
  "contributors": [
    {
      "name": "Oz",
      "email": "oz-agent@warp.dev"
    }
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/MolochDaGod/ObjectStore/issues"
  },
  "homepage": "https://objectstore.grudge-studio.com",
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.3.0",
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/extensions": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "@types/node": "^20.0.0",
    "draco3dgltf": "^1.5.7",
    "gh-pages": "^6.3.0",
    "meshoptimizer": "^1.1.0",
    "obj2gltf": "^3.2.0",
    "sharp": "^0.33.5",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "funding": {
    "type": "individual",
    "url": "https://grudgewarlords.com/support"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.665.0",
    "@heyputer/puter.js": "^2.2.15",
    "adm-zip": "^0.5.17",
    "cloudflare": "^5.2.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "gltf-pipeline": "^4.3.0",
    "jose": "^5.9.6",
    "multer": "^2.1.1",
    "obj2gltf": "^3.2.0"
  }
}
